<?xml version="1.0"?>
<launch>
  <arg name="world" default="boxes3" />
  <arg name="yaw" default="0.0" />

<!-- BEGIN ROBOT 0 --> 
  <group ns="robot0">
    <param name="tf_prefix" value="robot0_tf" />
    <include file="$(find multiple_robot_navigation)/launch/generated/boxes3/one_robot0_nav.launch" >
    <arg name="init_pose" value="-x 3 -y 15.5 -z 0.0 -Y $(arg yaw)" />
      <arg name="namespace"  value="robot0" />
    </include>
  </group> 

<!-- BEGIN ROBOT 1 -->
  <group ns="robot1">
    <param name="tf_prefix" value="robot1_tf" />
    <include file="$(find multiple_robot_navigation)/launch/generated/boxes3/one_robot1_nav.launch" >
    <arg name="init_pose" value="-x -3.08911896281 -y 15.1672524873 -z 0.0 -Y $(arg yaw)" />
      <arg name="namespace"  value="robot1" />
    </include>
  </group>


<!-- BEGIN ROBOT 2 
  <group ns="robot2">
    <param name="tf_prefix" value="robot2_tf" />
    <include file="$(find multiple_robot_navigation)/launch/experiment1/one_robot2_nav.launch" >
    <arg name="init_pose" value="-x 2.00111906496 -y 15.6584561171 -z 0.0 -Y $(arg yaw)" />
      <arg name="namespace"  value="robot2" />
    </include>
  </group>

 BEGIN ROBOT 3 
  <group ns="robot3">
    <param name="tf_prefix" value="robot3_tf" />
    <include file="$(find multiple_robot_navigation)/launch/experiment1/one_robot3_nav.launch" >
    <arg name="init_pose" value="-x 7.4229974243 -y 15.1171522974 -z 0.0 -Y $(arg yaw)" />
      <arg name="namespace"  value="robot3" />
    </include>
  </group> -->


<!-- Map publisher node -->
  <node name="map_publisher" pkg="map_server" type="map_server"
    args="$(find planning_worlds)/worlds/map_$(arg world).yaml" output="screen" />

</launch>

