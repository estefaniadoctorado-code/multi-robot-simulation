<?xml version="1.0"?>
<launch>
  <param name="/use_sim_time" value="true" />
  <arg name="world" default="boxes3" />
  <arg name="type" default="nav" />

  <!-- start world -->
  <node name="gazebo" pkg="gazebo_ros" type="gazebo" 
    args="$(find planning_worlds)/worlds/$(arg world).world" respawn="false" output="screen" />

  <!-- launch all robots -->
  <include file="$(find multiple_robot_navigation)/launch/generated/boxes3/generated_robots_$(arg type).launch">
    <arg name="world" value="$(arg world)" />
  </include>

</launch>

